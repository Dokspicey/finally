# Required: OpenAI API key for LLM chat functionality.
OPENAI_API_KEY=

# Optional: Massive (Polygon.io) API key for real market data.
# If unset or empty, the built-in market simulator is used.
MASSIVE_API_KEY=

# Optional: when "true", the backend returns deterministic mock LLM responses
# instead of calling OpenAI. Used by E2E tests and offline development.
LLM_MOCK=false
